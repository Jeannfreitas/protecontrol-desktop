{
  "name": "protecontrol-desktop",
  "version": "1.0.0",
  "description": "Sistema de controle de trabalhos protéticos",
  "main": "./electron.js",
  "author": "Jean Nascimento",
  "homepage": "./",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "electron": "concurrently \"npm start\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.protecontrol.app",
    "productName": "ProteControl",
    "win": {
      "target": "nsis"
    },
    "files": [
      "build/**/*",
      "electron.js",
      "preload.js"
    ],
    "extraMetadata": {
      "main": "electron.js"
    }
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "sql.js": "^1.14.1",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "better-sqlite3": "^9.4.3",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
